{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "moduleResolution": "node",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "outDir": "./dist",
    "rootDir": "../../packages",
    "declaration": true,
    "sourceMap": true,
    "paths": {
      "@minesweeper-pvp/shared": ["../shared/src/index"]
    }
  },
  "include": ["src", "../shared/src"]
}
