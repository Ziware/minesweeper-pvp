# Основной домен сайта (без https:// и без слэшей).
DOMAIN=example.com

# Email для уведомлений Let's Encrypt об истечении сертификата.
LETSENCRYPT_EMAIL=admin@example.com

# ─── Режим отладки (HTTP без SSL) ────────────────────────────────────────────
# Установи IS_DEBUG=true для запуска по IP без SSL (локально / на ВМ без домена).
# В этом режиме nginx отдаёт HTTP на порту 80, сертификат не нужен.
IS_DEBUG=false

# CORS для API — укажи явно при IS_DEBUG=true (например http://1.2.3.4)
# По умолчанию (если не задано) используется https://${DOMAIN}
# CORS_ORIGINS=http://your-vm-ip-or-domain

# ─── PostgreSQL ───────────────────────────────────────────────────────────────
POSTGRES_USER=minesweeper
POSTGRES_PASSWORD=changeme_strong_password

# ─── Internal API key (Backend → API) ────────────────────────────────────────
# Shared secret for backend (socket.io) to call internal API endpoints.
# Generate: openssl rand -hex 32
INTERNAL_API_KEY=your-internal-api-key-at-least-32-chars-here

# ─── JWT ─────────────────────────────────────────────────────────────────────
# Минимум 32 случайных символа. Сгенерировать: openssl rand -hex 32
JWT_SECRET=your-very-long-random-secret-at-least-32-chars-here

# ─── SMTP (для отправки кода верификации email) ───────────────────────────────
# Провайдер: Brevo (smtp-relay.brevo.com)
# SMTP_USER  — email вашего аккаунта Brevo (логин)
# SMTP_PASS  — SMTP Key из Brevo: Settings → SMTP & API → SMTP Keys
# SMTP_FROM  — адрес отправителя, верифицированный в Brevo
#              (Senders & IPs → Senders → Add a sender)
SMTP_HOST=smtp-relay.brevo.com
SMTP_PORT=587
SMTP_USER=your-brevo-account@example.com
SMTP_PASS=your-brevo-smtp-key
SMTP_FROM=Minesweeper PvP <noreply@yourdomain.com>
